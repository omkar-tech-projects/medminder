# ─────────────────────────────────────────────────────────────────────────────
# MedMinder — environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic API key — SERVER-SIDE ONLY. Never prefix with EXPO_PUBLIC_.
# Obtain from https://console.anthropic.com → API Keys.
# This key is read by app/api/analyse+api.ts (server) and is never sent to
# the mobile client.
ANTHROPIC_API_KEY=sk-ant-...

# Base URL of the API server — READ BY THE MOBILE CLIENT.
#
# Development (iOS Simulator / Android Emulator):
#   Leave this unset. The app auto-detects the Expo dev server URL from
#   Constants.expoConfig.hostUri (e.g. http://192.168.1.5:8081).
#
# Development (real device):
#   Set this to the IP shown by `npx expo start`, e.g.:
#   EXPO_PUBLIC_API_BASE_URL=http://192.168.1.5:8081
#
# Production:
#   Set this to your deployed server URL, e.g.:
#   EXPO_PUBLIC_API_BASE_URL=https://api.medminder.example.com
#
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.5:8081

# ─────────────────────────────────────────────────────────────────────────────
# How to run the API server locally
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Copy this file:
#      cp .env.local.example .env.local
#
# 2. Set ANTHROPIC_API_KEY in .env.local
#
# 3. Start Expo (this also starts the API route server):
#      npx expo start
#
#    The API route is available at:
#      http://localhost:8081/api/analyse    (simulator)
#      http://<your-IP>:8081/api/analyse   (real device — IP shown in terminal)
#
# 4. The web output mode is set to "server" in app.json, which is required
#    for Expo Router API routes. This has no effect on iOS/Android builds.
