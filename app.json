{
  "expo": {
    "name": "MedMinder",
    "slug": "medminder",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medminder",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.medminder.app",
      "infoPlist": {
        "NSCameraUsageDescription": "MedMinder uses the camera to scan your prescription.",
        "NSPhotoLibraryUsageDescription": "MedMinder accesses your photos to upload a prescription image.",
        "NSCalendarsUsageDescription": "MedMinder can add dose reminders to your calendar.",
        "NSFaceIDUsageDescription": "MedMinder uses Face ID to protect your medication data."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.medminder.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "MedMinder uses the camera to scan your prescription."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MedMinder accesses your photos to upload a prescription image."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#4F46E5"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "MedMinder uses Face ID to protect your medication data."
        }
      ],
      "expo-sqlite",
      "expo-status-bar",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
